{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@kitsra/kavio-browser-renderer": ["./packages/browser-renderer/src/index.ts"],
      "@kitsra/kavio-builder": ["./packages/builder/src/index.ts"],
      "@kitsra/kavio-cli": ["./packages/cli/src/index.ts"],
      "@kitsra/kavio-core": ["./packages/core/src/index.ts"],
      "@kitsra/kavio-ffmpeg": ["./packages/ffmpeg/src/index.ts"],
      "@kitsra/kavio-mcp": ["./packages/mcp/src/index.ts"],
      "@kitsra/kavio-render": ["./packages/render/src/index.ts"],
      "@kitsra/kavio-render-worker": ["./packages/render-worker/src/index.ts"],
      "@kitsra/kavio-schema": ["./packages/schema/src/index.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": "src",
    "strict": true,
    "target": "ES2023",
    "verbatimModuleSyntax": true
  }
}
