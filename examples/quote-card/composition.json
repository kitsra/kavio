{
  "version": "0.1",
  "props": {
    "quote": {
      "type": "string",
      "description": "The quote text."
    },
    "author": {
      "type": "string",
      "description": "Attribution line."
    },
    "accent": {
      "type": "string",
      "default": "#f2a03d",
      "description": "Accent bar color."
    }
  },
  "composition": {
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "durationFrames": 1,
    "background": "#101820"
  },
  "assets": {},
  "layers": [
    {
      "id": "bg",
      "type": "shape",
      "shape": "rect",
      "fill": "#101820",
      "startFrame": 0,
      "durationFrames": 1
    },
    {
      "id": "accent",
      "type": "shape",
      "shape": "rect",
      "fill": "{{accent}}",
      "startFrame": 0,
      "durationFrames": 1,
      "position": {
        "x": 120,
        "y": 300
      },
      "anchor": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 12,
        "height": 480
      }
    },
    {
      "id": "quote",
      "type": "text",
      "text": "“{{quote}}”",
      "startFrame": 0,
      "durationFrames": 1,
      "position": {
        "x": 180,
        "y": 330
      },
      "anchor": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 780
      },
      "style": {
        "fontSize": 56,
        "fontWeight": 700,
        "color": "#f5f2ea",
        "lineHeight": 1.3,
        "wrap": true
      }
    },
    {
      "id": "author",
      "type": "text",
      "text": "— {{author}}",
      "startFrame": 0,
      "durationFrames": 1,
      "position": {
        "x": 180,
        "y": 700
      },
      "anchor": {
        "x": 0,
        "y": 0
      },
      "style": {
        "fontSize": 32,
        "color": "#9aa7b0"
      }
    }
  ],
  "audio": [],
  "exports": [
    {
      "name": "square-card",
      "format": "png",
      "width": 1080,
      "height": 1080
    },
    {
      "name": "story-card",
      "format": "png",
      "width": 1080,
      "height": 1920
    },
    {
      "name": "transparent-card",
      "format": "png",
      "width": 1080,
      "height": 1080,
      "background": "transparent"
    }
  ]
}
