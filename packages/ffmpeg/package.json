{
  "name": "@kitsra/kavio-ffmpeg",
  "version": "0.2.0",
  "description": "FFmpeg planning primitives for Kavio rendering.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsra/kavio.git"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kitsra/kavio-schema": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "!dist/self-check.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node dist/self-check.js"
  }
}
