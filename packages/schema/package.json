{
  "name": "@kitsra/kavio-schema",
  "version": "0.0.0",
  "description": "Canonical Kavio JSON Schema, TypeScript types, and validation contract.",
  "license": "Elastic-2.0",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./schema/kavio-0.1.schema.json"
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "schema"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node test/validate-composition.mjs"
  }
}
