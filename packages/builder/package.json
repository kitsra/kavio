{
  "name": "@kitsra/kavio-builder",
  "version": "0.1.3",
  "description": "TypeScript builder SDK for creating Kavio JSON.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsra/kavio.git"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kitsra/kavio-core": "workspace:*",
    "@kitsra/kavio-schema": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node test/validate.mjs"
  }
}
