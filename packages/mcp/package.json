{
  "name": "@kitsra/kavio-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server and provider tool adapters for Kavio.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsra/kavio.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "kavio-mcp": "./dist/bin.js"
  },
  "dependencies": {
    "@kitsra/kavio-builder": "workspace:*",
    "@kitsra/kavio-core": "workspace:*",
    "@kitsra/kavio-render": "workspace:*",
    "@kitsra/kavio-render-worker": "workspace:*",
    "@kitsra/kavio-schema": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "plugins",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test test/*.test.mjs"
  }
}
