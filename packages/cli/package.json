{
  "name": "@kitsra/kavio-cli",
  "version": "0.1.0",
  "description": "Local CLI for Kavio validation, migration, preview, and rendering.",
  "license": "Elastic-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "kavio": "./dist/index.js"
  },
  "dependencies": {
    "@kitsra/kavio-builder": "workspace:*",
    "@kitsra/kavio-core": "workspace:*",
    "@kitsra/kavio-render": "workspace:*",
    "@kitsra/kavio-schema": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -b tsconfig.json && node --test test/*.test.mjs"
  }
}
