{
  "version": "0.1",
  "composition": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "durationFrames": 90,
    "background": "#101820"
  },
  "props": {
    "headline": {
      "type": "string",
      "default": "Launch ready"
    },
    "clipUrl": {
      "type": "url",
      "required": true
    }
  },
  "assets": {
    "clip": {
      "type": "video",
      "src": "{{clipUrl}}"
    },
    "logo": {
      "type": "image",
      "src": "https://example.com/logo.png"
    }
  },
  "layers": [
    {
      "id": "clip",
      "type": "video",
      "asset": "clip",
      "startFrame": 0,
      "durationFrames": 90,
      "fit": "cover"
    },
    {
      "id": "headline",
      "type": "text",
      "text": "{{headline}}",
      "startFrame": 12,
      "durationFrames": 48,
      "position": {
        "x": 540,
        "y": 340
      },
      "anchor": "center",
      "style": {
        "fontFamily": "Inter",
        "fontSize": 64,
        "fontWeight": 700,
        "color": "#ffffff",
        "align": "center"
      }
    }
  ],
  "audio": [],
  "exports": [
    {
      "name": "social",
      "format": "mp4",
      "codec": "h264",
      "width": 1080,
      "height": 1920
    }
  ]
}
