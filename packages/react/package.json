{
  "name": "@kitsra/kavio-react",
  "version": "0.4.1",
  "description": "Opt-in React frame rendering for Kavio's Playwright and FFmpeg pipeline.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsra/kavio.git"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kitsra/kavio-render": "workspace:*",
    "@kitsra/kavio-schema": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "!dist/self-check.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node dist/self-check.js"
  }
}
