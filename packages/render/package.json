{
  "name": "@kitsra/kavio-render",
  "version": "0.2.0",
  "description": "Render execution layer for Kavio: browser frame capture and FFmpeg encoding.",
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsra/kavio.git"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kitsra/kavio-browser-renderer": "workspace:*",
    "@kitsra/kavio-core": "workspace:*",
    "@kitsra/kavio-ffmpeg": "workspace:*",
    "@kitsra/kavio-render-worker": "workspace:*",
    "@kitsra/kavio-schema": "workspace:*"
  },
  "optionalDependencies": {
    "ffmpeg-static": "5.3.0",
    "playwright": "1.50.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "!dist/self-check.*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "install:browsers": "playwright install chromium",
    "install:ffmpeg": "corepack pnpm rebuild ffmpeg-static",
    "prepack": "node ../../scripts/verify-render-optional-deps.mjs",
    "test": "tsc -p tsconfig.json && node dist/self-check.js",
    "test:e2e": "tsc -p tsconfig.json && node test/e2e.mjs"
  }
}
